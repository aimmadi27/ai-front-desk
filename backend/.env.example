# Database (Supabase — use the "Transaction" pooler URL for production)
DATABASE_URL=postgresql+asyncpg://postgres:[password]@db.[project].supabase.co:5432/postgres

# Redis (Upstash or local)
REDIS_URL=redis://localhost:6379/0

# Google Cloud
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=

# Gemini
GEMINI_API_KEY=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# SendGrid
SENDGRID_API_KEY=

# Airtable
AIRTABLE_API_KEY=

# Sentry
SENTRY_DSN=

# Internal
SCHEDULER_SECRET=change-me-in-production

# App
APP_ENV=development
BASE_URL=http://localhost:8000
